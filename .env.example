# SentinelAI — Enterprise Runtime AI Governance Platform
# Copy this file to .env and fill in your values

# -----------------------------------------------
# Google Gemini API Key (for real AI agent calls)
# Get yours at: https://aistudio.google.com/apikey
# -----------------------------------------------
GEMINI_API_KEY=your-gemini-api-key-here

# -----------------------------------------------
# Audit Storage Backend
# false = SQLite (local dev, ephemeral on ECS)
# true  = DynamoDB (required for AWS production)
# -----------------------------------------------
USE_DYNAMODB=false

# -----------------------------------------------
# Dry Run Mode
# true  = evaluate policy but never block/hold (testing only)
# false = full enforcement (production default)
# -----------------------------------------------
DRY_RUN=false

# -----------------------------------------------
# AWS Configuration (required if USE_DYNAMODB=true)
# -----------------------------------------------
AWS_DEFAULT_REGION=us-east-1
AUDIT_TABLE=action_guard_audit

# -----------------------------------------------
# Default Governance Policy Version
# v1 = basic rules (2 rules)
# v2 = intermediate rules
# v3 = full 9-layer enterprise protection (recommended)
# -----------------------------------------------
ACTIVE_POLICY_VERSION=v3

# -----------------------------------------------
# Autonomous Monitoring Agent Configuration
# ENABLE_MONITOR: true to start the background monitoring loop
# MONITOR_INTERVAL: time in seconds between inbox polling cycles
# -----------------------------------------------
ENABLE_MONITOR=false
MONITOR_INTERVAL=30
